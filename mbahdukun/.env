# App
app.baseURL = 'https://mbahdukun.web.id/'
app.indexPage = ''
app.appTimezone = 'Asia/Jakarta'
app.CSPEnabled = false

# Security
SECURITY.encryptionKey = ''

# Database (set your own)
database.default.hostname = localhost
database.default.database = mbahdukun
database.default.username = root
database.default.password = ''
database.default.DBDriver = MySQLi
database.default.DBPrefix = ''
database.default.port     = 3306

# Email (iCloud SMTP)
email.fromEmail = 'noreply@mbahdukun.web.id'
email.fromName = 'Mbah Dukun'
email.protocol = 'smtp'
email.SMTPHost = 'smtp.mail.me.com'
email.SMTPUser = ''
email.SMTPPass = ''
email.SMTPPort = 587
email.SMTPCrypto = 'tls'

# Prices (IDR)
prices.jodoh = 5000
prices.tarot = 5000
prices.konsultasi = 5000

# Tripay
tripay.apiKey = ''
tripay.merchantCode = ''
tripay.privateKey = ''
tripay.qrisChannel = 'QRIS'
tripay.callbackURL = 'https://mbahdukun.web.id/payment/callback'
tripay.returnURL = 'https://mbahdukun.web.id/order/waiting'

# Gemini
gemini.apiKey = ''
gemini.model = 'gemini-2.0-flash-exp'

# Admin
admin.email = 'admin@mbahdukun.web.id'
admin.passwordHash = ''  # isi dengan password hash bcrypt