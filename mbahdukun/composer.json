{
  "name": "mbahdukun/web",
  "description": "Website ramalan Mbah Dukun (CodeIgniter 4)",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "codeigniter4/framework": "^4.5",
    "guzzlehttp/guzzle": "^7.8",
    "dompdf/dompdf": "^2.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "mikey179/vfsstream": "^1.6",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "scripts": {
    "post-update-cmd": [
      "php spark migrate --all"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}